{
  "name": "@currencycore/sdk",
  "version": "0.1.1",
  "description": "Official CurrencyCore API client for TypeScript, Node.js, and React Native.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CurrencyCore/currencycore-typescript.git"
  },
  "homepage": "https://currency-core.com",
  "keywords": [
    "currencycore",
    "currency",
    "exchange-rates",
    "forex",
    "ppp",
    "fx",
    "api",
    "sdk"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepare": "npm run build",
    "generate": "bash scripts/generate.sh"
  },
  "devDependencies": {
    "typescript": "^4.0 || ^5.0"
  }
}
